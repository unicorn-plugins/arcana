{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Arcana Skill Data",
  "type": "object",
  "required": [
    "id",
    "name",
    "direction",
    "cost",
    "target",
    "effects"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "direction": {
      "type": "string",
      "enum": [
        "forward",
        "reverse",
        "ultimate"
      ]
    },
    "cost": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "target": {
      "type": "string",
      "enum": [
        "single_enemy",
        "all_enemies",
        "single_ally",
        "all_allies",
        "self"
      ]
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "type",
          "value"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "damage",
              "heal",
              "buff",
              "debuff",
              "remove_debuff",
              "remove_skill",
              "shield",
              "counter"
            ]
          },
          "value": {
            "type": "number"
          },
          "stat": {
            "type": "string",
            "enum": [
              "attack",
              "defense",
              "hp"
            ]
          },
          "duration": {
            "type": "integer"
          },
          "scaling": {
            "type": "string"
          }
        }
      }
    }
  }
}